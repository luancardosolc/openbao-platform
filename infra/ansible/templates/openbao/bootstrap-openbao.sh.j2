#!/usr/bin/env bash
set -euo pipefail

bootstrap_file="/opt/openbao/bootstrap/bootstrap.json"
bootstrap_tmp="$(mktemp /tmp/openbao-bootstrap.XXXXXX)"
audit_file="/opt/openbao/logs/audit.log"
bao_addr="https://{{ ansible_host }}:{{ openbao_ui_port }}"

cleanup() {
  rm -f "${bootstrap_tmp}"
}

trap cleanup EXIT

bootstrap_file_valid="false"
if [[ -s "${bootstrap_file}" ]] && python3 - "${bootstrap_file}" <<'PY' >/dev/null 2>&1
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    payload = json.load(handle)

assert payload["root_token"]
assert payload["unseal_keys_b64"][0]
PY
then
  bootstrap_file_valid="true"
fi

status_json="$(
  docker exec -e BAO_ADDR="${bao_addr}" -e BAO_SKIP_VERIFY=true openbao \
    bao status -format=json 2>/dev/null || true
)"

initialized="false"
sealed="true"

if [[ -n "${status_json}" ]]; then
  if grep -q '"initialized": true' <<<"${status_json}"; then
    initialized="true"
  fi
  if grep -q '"sealed": false' <<<"${status_json}"; then
    sealed="false"
  fi
fi

if [[ "${initialized}" != "true" || "${bootstrap_file_valid}" != "true" ]]; then
  docker exec -e BAO_ADDR="${bao_addr}" -e BAO_SKIP_VERIFY=true openbao \
    bao operator init -format=json > "${bootstrap_tmp}"
  mv "${bootstrap_tmp}" "${bootstrap_file}"
  sealed="true"
fi

root_token="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["root_token"])' "${bootstrap_file}")"

if [[ "${sealed}" == "true" ]]; then
python3 - "${bootstrap_file}" <<'PY' | while IFS= read -r unseal_key; do
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    payload = json.load(handle)

for key in payload["unseal_keys_b64"][:3]:
    print(key)
PY
  docker exec -e BAO_ADDR="${bao_addr}" -e BAO_SKIP_VERIFY=true openbao \
    bao operator unseal "${unseal_key}" >/dev/null
done
fi

docker exec -e BAO_ADDR="${bao_addr}" -e BAO_SKIP_VERIFY=true \
  -e BAO_TOKEN="${root_token}" openbao \
  bao audit enable file file_path="${audit_file}" >/dev/null 2>&1 || true
docker exec -e BAO_ADDR="${bao_addr}" -e BAO_SKIP_VERIFY=true \
  -e BAO_TOKEN="${root_token}" openbao \
  bao secrets enable -path=kv kv-v2 >/dev/null 2>&1 || true
docker exec -i -e BAO_ADDR="${bao_addr}" -e BAO_SKIP_VERIFY=true \
  -e BAO_TOKEN="${root_token}" openbao \
  bao policy write platform-admin - </opt/openbao/config/platform-policy.hcl >/dev/null
openssl enc -aes-256-cbc -salt -pbkdf2 -in "${bootstrap_file}" -out "${bootstrap_file}.enc" -pass pass:openbao-bootstrap >/dev/null 2>&1
